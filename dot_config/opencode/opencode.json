{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openai"],
  "agent": {
    "plan": {
      "disable": true
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "bash": {
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "glab mr diff *": "allow",
      "glab mr note list *": "allow",
      "glab ci get *": "allow",
      "glab ci trace *": "allow"
    },
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "deny",
    "external_directory": {
      "*": "ask"
    }
  },
  "share": "disabled",
  "tui": {
    "diff_style": "stacked"
  },
  "autoupdate": false
}
