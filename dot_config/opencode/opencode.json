{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["github-copilot", "openai"],
  "model": "github-copilot/claude-haiku-4.5",
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "plan": {
      "disable": true
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "glab issue list *": "allow",
      "glab issue view *": "allow",
      "glab mr list *": "allow",
      "glab mr view *": "allow",
      "glab mr diff *": "allow"
    },
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "deny"
  },
  "share": "disabled",
  "tui": {
    "diff_style": "stacked"
  },
  "autoupdate": false
}
