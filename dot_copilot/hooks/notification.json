{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "powershell": "sh -c 'notify copilot agentStop'",
        "bash": "notify copilot agentStop"
      }
    ],
    "permissionRequest": [
      {
        "type": "command",
        "powershell": "sh -c 'notify copilot permissionRequest'",
        "bash": "notify copilot permissionRequest"
      }
    ]
  }
}
