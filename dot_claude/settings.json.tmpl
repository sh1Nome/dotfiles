{
  "respectGitignore": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": ["Read(//**/.env)", "Read(//**/.env.*)"]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            {{ if eq .chezmoi.os "windows" }}
            "command": "Add-Type -AssemblyName System.Windows.Forms,System.Drawing;$n=[System.Windows.Forms.NotifyIcon]::new();$n.Icon=[System.Drawing.SystemIcons]::Information;$n.Visible=$true;$n.ShowBalloonTip(5000,'Claude','Stop',[System.Windows.Forms.ToolTipIcon]::Info)"
            {{ else }}
            "command": "notify-send Claude Stop"
            {{ end }}
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            {{ if eq .chezmoi.os "linux" }}
            "command": "notify-send Claude Notification"
            {{ end }}
            {{ if eq .chezmoi.os "windows" }}
            "command": "Add-Type -AssemblyName System.Windows.Forms,System.Drawing;$n=[System.Windows.Forms.NotifyIcon]::new();$n.Icon=[System.Drawing.SystemIcons]::Information;$n.Visible=$true;$n.ShowBalloonTip(5000,'Claude','Notification',[System.Windows.Forms.ToolTipIcon]::Info)"
            {{ end }}
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline.sh",
    "padding": 2
  },
  "defaultShell": "bash",
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "fastModePerSessionOptIn": true,
  "externalEditorContext": true,
  "tui": "fullscreen",
  "theme": "dark",
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": false,
  "autoConnectIde": false,
  "autoInstallIdeExtension": false,
  "disableAutoMode": "disable",
  "disableDeepLinkRegistration": "disable"
}
